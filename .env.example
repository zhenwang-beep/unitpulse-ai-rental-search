# Copy to `.env.local` for local development overrides.
# In deployed environments (Vercel today, AWS post-migration), set these
# in the platform's env-var settings — engineering owns the deploy infra.
#
# Tri-state: "true", "false", or unset.
# Unset → production: OFF. dev: ON (the dev default in featureFlags.ts).

# Gemini API key — required for any AI feature to function.
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- AI feature flags ---
# See featureFlags.ts for what each one gates. Engineering can flip these
# per-environment when each feature is ready to ship to production.

VITE_FEATURE_AI_CHAT=
VITE_FEATURE_AI_VOICE=
VITE_FEATURE_AI_LIFESTYLE_MATCH=
VITE_FEATURE_AI_PREFERENCES=
